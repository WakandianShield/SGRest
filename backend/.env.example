NODE_ENV=development
PORT=3000
API_PREFIX=api

# PostgreSQL
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/sgrest"

# JWT (RS256)
# Usa llaves reales en formato PEM en produccion.
JWT_ACCESS_TOKEN_PRIVATE_KEY="replace-with-real-private-key"
JWT_ACCESS_TOKEN_PUBLIC_KEY="replace-with-real-public-key"
JWT_ACCESS_TOKEN_EXPIRES_IN=15m
JWT_REFRESH_TOKEN_PRIVATE_KEY="replace-with-real-private-key"
JWT_REFRESH_TOKEN_PUBLIC_KEY="replace-with-real-public-key"
JWT_REFRESH_TOKEN_EXPIRES_IN=7d

# Cookies / CORS
COOKIE_DOMAIN=localhost
COOKIE_SECURE=false
CORS_ORIGIN=http://localhost:5173

# Socket.IO
SOCKET_CORS_ORIGIN=http://localhost:5173

# SendGrid
SENDGRID_API_KEY="replace-with-sendgrid-key"
MAIL_FROM="no-reply@sgrest.dev"
MANAGER_EMAIL="manager@example.com"
OWNER_EMAIL="owner@example.com"

# Expo push
EXPO_ACCESS_TOKEN="replace-with-expo-access-token"

# Logs / observabilidad
LOG_LEVEL=debug
